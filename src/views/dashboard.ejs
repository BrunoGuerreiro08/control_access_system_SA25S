<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <style>
    * { box-sizing: border-box; }
    body {
      font-family: Arial;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      background-color: #f5f5f5;
    }
    .dashboard-box {
      background: white;
      padding: 20px;
      border-radius: 8px;
      width: 400px;
    }
    .error {
      background-color: #f8d7da;
      color: #842029;
      padding: 10px;
      border-radius: 4px;
      margin-bottom: 10px;
    }
    .resource-item {
      padding: 10px;
      margin-bottom: 8px;
      border-radius: 4px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .resource-item.accessible {
      background-color: #d1e7dd;
      cursor: pointer;
    }
    .resource-item.locked {
      background-color: #f8d7da;
      cursor: not-allowed;
    }
    a {
      text-decoration: none;
      color: inherit;
      cursor: inherit;
    }
    .logout {
      display: block;
      width: 100%;
      padding: 10px;
      margin-top: 15px;
      background-color: #d9534f;
      color: white;
      text-align: center;
      text-decoration: none;
      border-radius: 4px;
    }
    .logout:hover { background-color: #c9302c; }

    .create-btn {
      display: block;
      width: 100%;
      padding: 10px;
      margin-bottom: 15px;
      background-color: #0d6efd;
      color: white;
      text-align: center;
      text-decoration: none;
      border-radius: 4px;
    }
    .create-btn:hover { background-color: #0b5ed7; }

    .warning {
      background-color: #fff3cd;
      color: #856404;
      padding: 10px;
      border-radius: 4px;
      margin-bottom: 10px;
    }
  </style>
</head>
<body>
  <div class="dashboard-box">
    <h2>Dashboard</h2>
    <p><strong>Username:</strong> <%= user.username %></p>
    <p><strong>Clearance Level:</strong> <%= user.clearanceLevel %></p>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    <% if (warning) { %>
      <div class="warning"><%= warning %></div>
    <% } %>

    <h3>Resources</h3>
    <% resources.forEach(r => { %>
      <div class="resource-item <%= r.accessible ? 'accessible' : 'locked' %>">
        <% if (r.accessible) { %>
          <a href="/resource/<%= r.id %>"><%= r.content %></a>
        <% } else { %>
          <a href="/resource/<%= r.id %>"><%= r.content %></a>
        <% } %>
        <small>Level <%= r.classificationLevel %></small>
      </div>
    <% }) %>

    <a class="create-btn" href="/resource/create">+ New Resource</a>
    <a class="logout" href="/logout">Logout</a>
  </div>
</body>
</html>