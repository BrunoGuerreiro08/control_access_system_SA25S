<!DOCTYPE html>
<html>
<head>
  <title>Login</title>

  <style>
    * { box-sizing: border-box; }
    
    body {
      font-family: Arial;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      background-color: #f5f5f5;
    }

    .login-box {
      background: white;
      padding: 20px;
      border-radius: 8px;
      width: 300px;
    }

    input {
      width: 100%;
      margin-bottom: 10px;
      padding: 8px;
    }

    button {
      width: 100%;
      padding: 10px;
    }
  </style>
</head>

<body>

  <div class="login-box">
    <h2>Login</h2>

    <form method="POST" action="/login">
      <input 
        type="text" 
        name="username" 
        value="<%= typeof username !== 'undefined' ? username : '' %>"
        placeholder="Username">
        
      <input type="password" name="password" placeholder="Password">

      <button type="submit">Login</button>
    </form>
    <a href="/auth/google" style="display:block; text-align:center; margin-top:10px;">
    Login with Google
    </a>
    <a href="/register">Don't have an account? Register</a>
  </div>

</body>
</html>