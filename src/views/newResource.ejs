<!DOCTYPE html>
<html>
<head>
  <title>New Resource</title>
  <style>
    * { box-sizing: border-box; }
    body {
      font-family: Arial;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      background-color: #f5f5f5;
    }
    .box {
      background: white;
      padding: 20px;
      border-radius: 8px;
      width: 350px;
    }
    input, select, textarea {
      width: 100%;
      margin-bottom: 10px;
      padding: 8px;
    }
    textarea { resize: vertical; height: 100px; }
    button {
      width: 100%;
      padding: 10px;
    }
    .error {
      background-color: #f8d7da;
      color: #842029;
      padding: 8px;
      border-radius: 4px;
      margin-bottom: 10px;
    }
    a {
      display: block;
      text-align: center;
      margin-top: 10px;
      color: #555;
      font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="box">
    <h2>New Resource</h2>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <form method="POST" action="/resource/create">
      <textarea name="content" placeholder="Resource content" required></textarea>
        <select name="classificationLevel">
        <% Object.entries(levels).forEach(([name, value]) => { %>
            <option value="<%= value %>"><%= name %></option>
        <% }) %>
        </select>
      <button type="submit">Create</button>
    </form>

    <a href="/dashboard">Back to Dashboard</a>
  </div>
</body>
</html>