<!DOCTYPE html>
<html>
<head>
  <title>Resource</title>
  <style>
    * { box-sizing: border-box; }
    body {
      font-family: Arial;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      background-color: #f5f5f5;
    }
    .resource-box {
      background: white;
      padding: 20px;
      border-radius: 8px;
      width: 400px;
    }
    a {
      display: block;
      width: 100%;
      padding: 10px;
      margin-top: 15px;
      background-color: #0d6efd;
      color: white;
      text-align: center;
      text-decoration: none;
      border-radius: 4px;
    }
    a:hover { background-color: #0b5ed7; }
  </style>
</head>
<body>
  <div class="resource-box">
    <h2>Resource</h2>
    <p><strong>Content:</strong> <%= resource.content %></p>
    <p><strong>Classification Level:</strong> <%= resource.classificationLevel %></p>

    <a href="/dashboard">Back to Dashboard</a>
  </div>
</body>
</html>